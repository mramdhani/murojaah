# Murojaah — Git Ignore Config

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -------------------------------------------------------------------------
# Laravel API ignores
# -------------------------------------------------------------------------
/api/.env
/api/bootstrap/cache/*
!/api/bootstrap/cache/.gitignore
/api/storage/framework/cache/data/*
!/api/storage/framework/cache/data/.gitignore
/api/storage/framework/sessions/*
!/api/storage/framework/sessions/.gitignore
/api/storage/framework/testing/*
!/api/storage/framework/testing/.gitignore
/api/storage/framework/views/*
!/api/storage/framework/views/.gitignore
/api/storage/logs/*
!/api/storage/logs/.gitignore
/api/vendor/
/api/node_modules/
/api/public/storage
/api/public/hot
/api/storage/*.key
/api/config/pail.php

# SQLite database files if created locally
/api/database/*.sqlite
/api/database/*.sqlite-journal

# -------------------------------------------------------------------------
# Nuxt Web ignores
# -------------------------------------------------------------------------
/web/.env
/web/node_modules/
/web/.nuxt/
/web/.output/
/web/dist/
/web/npm-debug.log*
/web/yarn-debug.log*
/web/yarn-error.log*
/web/.pnpm-debug.log*

# Visual Studio Code template files
/web/.vscode/
